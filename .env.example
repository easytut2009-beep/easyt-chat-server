# انسخ إلى .env وعبّئ القيم

SUPABASE_URL=
SUPABASE_SERVICE_KEY=
OPENAI_API_KEY=

PORT=3000

# إلزامي في الإنتاج: NODE_ENV=production
# ADMIN_PASSWORD=

# اختياري: CORS إضافي للتطوير المحلي
# ALLOWED_ORIGIN=http://localhost:3000

# خلف nginx / Cloudflare — لـ rate limit و IP صحيح
# TRUST_PROXY=1

# أكثر من instance — حدود طلبات مشتركة
# REDIS_URL=redis://localhost:6379

# في الإنتاج: فتح /test?token=...
# TEST_SUITE_TOKEN=

# محرك الدردشة: gpt (افتراضي) أو legacy
# CHAT_ENGINE=gpt
# نموذج اختياري لوضع gpt
# GPT_CHAT_MODEL=gpt-4o-mini

# احتياطي لسعر الاشتراك الشهري/السنوي فقط إذا لم يُضف صف في bot_instructions (BOT_DYNAMIC | PRICING)
# أسعار الكورسات/الدبلومات من الجداول عبر الكتالوج — ليست من env
# SUBSCRIPTION_PRICE_MONTHLY_USD=25
# SUBSCRIPTION_PRICE_YEARLY_USD=59
# VODAFONE_CASH_NUMBER=01027007899
# SUPPORT_WHATSAPP_URL=https://wa.me/201027007899
# قسم «دورات الشهر» لسؤال أحدث الدورات
# COURSES_OF_THE_MONTH_URL=https://easyt.online/courses/category/b46e6075-f46c-4ee9-ae35-df49eee57095
